<!DOCTYPE html>
<html>
  <head>
    <title>AlphaBlog</title>
    <%= csrf_meta_tags %>
    <%= stylesheet_link_tag    'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body>
  <header>
    <h1>Daedalus</h1>
    <h2>Hero or Villan</h2>
    <h2>Which will you be?</h2>
  </header>
  <nav><%= link_to 'Home', root_path %> | <%= link_to 'About', about_path %> | <%= link_to 'Download', download_path %> | <%= link_to 'Blog', articles_path %> | <%= link_to 'Contact', contact_path %></nav>
  <div class="text_container">    <% flash.each do |name, msg| %>
    <ul>
      <li><%= msg %></li>
    </ul>
    <% end %>
    <%= yield %>
  </div>
  </body>
</html>
